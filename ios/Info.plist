<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CFBundleExecutable MUST match the built binary name (the CMake target
	     is "client"). Change both together if you rename it. -->
	<key>CFBundleExecutable</key>
	<string>client</string>

	<!-- Bundle ID must be UNIQUE per Apple ID for free-tier signing. If you
	     ever see "Failed to register bundle identifier", bump this. -->
	<key>CFBundleIdentifier</key>
	<string>win.penguins.kyrospades</string>

	<key>CFBundleName</key>
	<string>KyroSpades</string>
	<key>CFBundleDisplayName</key>
	<string>KyroSpades</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.5</string>
	<key>CFBundleVersion</key>
	<string>0.1.5</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>MinimumOSVersion</key>
	<string>13.0</string>

	<!-- 1 = iPhone, 2 = iPad. Drop the 2 if you only target iPhone. -->
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>

	<!-- Landscape only — matches SDL_HINT_ORIENTATIONS set in window.c. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Empty launch screen dict opts the app into full native resolution on
	     modern devices without needing a storyboard file. -->
	<key>UILaunchScreen</key>
	<dict/>

	<!-- The client speaks PLAINTEXT http (server list, version, news feed).
	     Without this, App Transport Security silently blocks every request and
	     the server browser shows up empty. Loosen to per-domain exceptions once
	     those endpoints move to https. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<key>UIStatusBarHidden</key>
	<true/>
	<key>UIRequiresFullScreen</key>
	<true/>

	<!-- Loose-PNG icon set generated by ios/make_icons.sh. iOS resolves
	     AppIcon60x60@2x.png (120) / @3x (180) for iPhone by device scale. -->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>AppIcon60x60</string>
			</array>
		</dict>
	</dict>
	<key>CFBundleIcons~ipad</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>AppIcon60x60</string>
				<string>AppIcon76x76</string>
			</array>
		</dict>
	</dict>
</dict>
</plist>
