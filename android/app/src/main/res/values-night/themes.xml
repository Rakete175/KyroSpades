<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Game theme: fullscreen black, no title bar, no action bar.
         SDL will take over the entire screen, so no Material colors needed. -->
    <style name="Theme.KyroSpades" parent="android:Theme.Black.NoTitleBar.Fullscreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>
</resources>
